# ──────────────────────────────────────────────
# TATA Group 360° Analytics — .gitignore
# ──────────────────────────────────────────────

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/
.env

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Raw data (large files — download separately)
data/raw/*.csv
data/raw/*.xls
data/raw/*.xlsx

# Processed data (regenerated by scripts)
data/processed/

# Streamlit cache
.streamlit/

# Logs
*.log

# Environment variables
.env
.env.local
